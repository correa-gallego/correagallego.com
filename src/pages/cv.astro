---
import Base from '../layouts/Base.astro';
---

<Base title="CV — Sebastian Correa-Gallego" description="Curriculum Vitae of Sebastian Correa-Gallego — Biology, Universidad EAFIT.">
  <h1 class="page-title">Curriculum Vitae</h1>

  <section class="cv-section reveal">
    <p>A full version of my CV is available as a PDF.</p>
    <a href="/assets/Correa-Gallego_CV.pdf" class="cv-download" download>
      Download CV
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M7 1v9m0 0L3.5 6.5M7 10l3.5-3.5M1 13h12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </section>

  <section class="cv-embed reveal">
    <object data="/assets/Correa-Gallego_CV.pdf" type="application/pdf" aria-label="Curriculum Vitae preview">
      <p class="cv-fallback">
        Your browser cannot display embedded PDFs.
        <a href="/assets/Correa-Gallego_CV.pdf" target="_blank" rel="noopener">Open the CV in a new tab</a>.
      </p>
    </object>
  </section>
</Base>
