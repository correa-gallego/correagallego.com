---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection, render } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const renderedProjects = await Promise.all(
  projects.map(async (project) => ({
    project,
    Content: (await render(project)).Content,
  }))
);
---

<Base title="Research — Sebastian Correa-Gallego" description="Research projects and technical methods — microbial ecology of cave systems and mitochondrial physiology in yeast. Sebastian Correa-Gallego, B.Sc. Biology, Universidad EAFIT (2026).">
  <header class="page-intro">
    <div class="container">
      <h1>Research</h1>
      <p class="page-intro__lede">
        The current portfolio is organized around two projects: a completed undergraduate
        thesis in cave microbiology and an ongoing collaboration on mitochondrial physiology
        in yeast.
      </p>
    </div>
  </header>

  <div class="container">
    <p class="research-interests reveal">
      Evolution and ecology are not subfields of biology — they are its organizing logic,
      present from the emergence of cellular complexity to the structure of communities in
      extreme environments. My research interests sit at this intersection: I am drawn to
      microbial systems as tractable windows into how life assembles, persists, and transforms
      under ecological and energetic constraint. This includes questions about community
      organization along environmental gradients, the physiological and molecular strategies
      that underlie ecological success, and the eco-evolutionary dynamics that connect cellular
      function to community-level patterns. I am also interested in the quantitative and
      computational frameworks that make these questions formally tractable, and in connecting
      field-based inquiry with analytical rigor across biological scales.
    </p>
  </div>

  <section class="section section--tight">
    <div class="container">
      <h2 class="section-title reveal">Projects</h2>
      <p class="section-lede reveal">
        These projects differ in setting, organism, and method, but together they define the
        current range of my work across microbial ecology and cellular physiology.
      </p>
    </div>
    <div class="container container--wide project-stack">
      {renderedProjects.map(({ project, Content }, index) => (
        <ProjectCard
          id={project.id}
          title={project.data.title}
          role={project.data.role}
          advisor={project.data.advisor}
          group={project.data.group}
          pi={project.data.pi}
          institutionName={project.data.institutionName}
          institutionLogo={project.data.institutionLogo}
          image={project.data.image}
          imageAlt={project.data.imageAlt}
          placeholder={project.data.placeholder}
          status={project.data.status}
          reversed={index % 2 === 1}
          aspectRatio={project.data.aspectRatio}
          tags={project.data.tags}
        >
          <Content />
          {project.id === 'cave' && (
            <div slot="support" class="figure-grid figure-grid--inline">
              <figure class="figure-card">
                <img
                  src="/assets/illustrations/cave_gradient.png"
                  alt="Working diagram of the cave light gradient used in the undergraduate thesis."
                  class="figure-card__image"
                  loading="lazy"
                  decoding="async"
                  width="4102"
                  height="2369"
                />
                <figcaption class="figure-card__caption">
                  Working cave-gradient diagram used in thesis development and presentation material.
                </figcaption>
              </figure>
              <figure class="figure-card">
                <img
                  src="/assets/illustrations/morphotypes_gradient.png"
                  alt="Figure showing morphotypes distributed across the cave light gradient."
                  class="figure-card__image"
                  loading="lazy"
                  decoding="async"
                  width="4024"
                  height="2415"
                />
                <figcaption class="figure-card__caption">
                  Morphotype summary across the sampled cave gradient.
                </figcaption>
              </figure>
            </div>
          )}
        </ProjectCard>
      ))}
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <h2 class="section-title reveal">Technical skills</h2>

      <div class="reveal">
        <div class="skills-group">
          <h3>Laboratory &amp; Biological Methods</h3>
          <div class="keywords">
            <span class="keyword">Microbial Cultivation</span>
            <span class="keyword">Environmental Sampling</span>
            <span class="keyword">Ecological Field Records</span>
            <span class="keyword">Morphotype Characterization</span>
            <span class="keyword">Yeast Handling</span>
            <span class="keyword">Cell Physiology</span>
            <span class="keyword">Microscopy</span>
          </div>
        </div>

        <div class="skills-group">
          <h3>Quantitative &amp; Computational</h3>
          <div class="keywords">
            <span class="keyword">R</span>
            <span class="keyword">Python</span>
            <span class="keyword">Linux / Bash</span>
            <span class="keyword">LaTeX</span>
            <span class="keyword">QGIS</span>
            <span class="keyword">Data Visualization</span>
            <span class="keyword">Bioinformatics</span>
          </div>
        </div>

        <div class="skills-group">
          <h3>Scientific &amp; Digital Workflows</h3>
          <div class="keywords">
            <span class="keyword">Scientific Writing</span>
            <span class="keyword">Research Communication</span>
            <span class="keyword">Literature Synthesis</span>
            <span class="keyword">Figure Preparation</span>
            <span class="keyword">Data Organization</span>
          </div>
        </div>

        <div class="skills-group">
          <h3>Languages</h3>
          <div class="keywords">
            <span class="keyword">Spanish (native)</span>
            <span class="keyword">English (working proficiency)</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
