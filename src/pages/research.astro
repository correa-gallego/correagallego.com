---
import Base from '../layouts/Base.astro';
import Entry from '../components/Entry.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionDivider from '../components/SectionDivider.astro';
---

<Base title="Research — Sebastian Correa-Gallego" description="Current research projects, academic trajectory, and technical skills.">
  <header class="page-intro">
    <div class="container">
      <span class="page-intro__eyebrow">Research</span>
      <h1>Two scales of life under constraint</h1>
      <p class="page-intro__lede">
        From the community structure of microorganisms in tropical volcanic caves
        to the cellular economics of yeast under varying carbon regimes &mdash;
        current work across field, laboratory, and quantitative approaches.
      </p>
    </div>
  </header>

  <section class="section section--tight">
    <div class="container container--wide">
      <ProjectCard
        id="cave"
        title="Cultivable Microbial Community Structure along a Light Gradient in a Tropical Volcaniclastic Cave"
        role="Undergraduate Thesis · Universidad EAFIT"
        advisor="Prof. Nicolás Pinel Peláez"
        description="Investigating the structure, diversity, and distributional patterns of cultivable microbial communities across a light-to-dark gradient in the Organal San Antonio, a volcaniclastic cave system in the Northwestern Andes of Colombia. The work integrates ecological field methods — including environmental characterization, zonation, and microclimatic measurement — with laboratory-based microbial cultivation, morphotype assessment, and quantitative community analysis. The cave represents an oligotrophic subterranean environment shaped by strong energetic and nutritional constraint, offering a natural gradient for studying how community assembly responds to resource limitation."
        image="/assets/project-cave.jpg"
        placeholder="cave"
        status="In preparation"
      />

      <ProjectCard
        id="yeast"
        title="Yeast Mitochondrial Proteome Allocation across Carbon Regimes"
        role="Visiting Student Intern · ECSO Lab, Purdue University"
        advisor="Dr. Shahed U. A. Shazib"
        pi="Dr. Sergio A. Muñoz-Gómez"
        description="Contributed to research on how eukaryotic cells allocate proteomic resources to mitochondria under different carbon regimes. The project investigates the relationship between mitochondrial function, proteome composition, and cellular organization across physiological conditions using Saccharomyces cerevisiae as a model system. Work involved organization, interpretation, and downstream analysis of biological datasets derived from proteomics-based workflows, including annotation-linked and comparative data exploration."
        image="/assets/project-yeast.jpg"
        placeholder="yeast"
        status="In preparation"
        reversed={true}
      />
    </div>
  </section>

  <SectionDivider label="Academic Trajectory" />

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <span class="section-head__eyebrow">Education</span>
        <span class="section-head__line"></span>
      </div>
      <Entry title="Universidad EAFIT" date="2022 – 2026 (expected)" role="B.Sc. in Biology">
        <p>Undergraduate researcher in microbial ecology. Thesis: cultivable microbial communities in a tropical volcaniclastic cave system from the Northwestern Andes, Colombia.</p>
      </Entry>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <span class="section-head__eyebrow">Academic Service</span>
        <span class="section-head__line"></span>
      </div>
      <Entry title="Student Director" date="Oct 2023 – Present" role="Research Group on Microbiology and Astrobiology · Universidad EAFIT">
        <p>
          Coordinate a student-led research group focused on microbiology, astrobiology, scientific
          discussion, and undergraduate research initiatives. Affiliated with the Research Group on
          Geosciences and Biodiversity (GEBI).
        </p>
      </Entry>
      <Entry title="Research Monitor" date="Jul 2024 – Dec 2024" role="Universidad EAFIT">
        <p>
          Contributed to the project <em>Positioning of Microorganisms as Fundamental Actors for
          the Maintenance of Andean Forests</em>, supporting project development through scientific
          systematization, written reporting, and research communication.
        </p>
      </Entry>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <span class="section-head__eyebrow">Early Research</span>
        <span class="section-head__line"></span>
      </div>
      <Entry title="Exploratory Projects" date="2022 – 2024" role="Environmental &amp; Extreme Microbiology · Universidad EAFIT">
        <p>
          Exploratory work on volcanic cave ecosystems, thermophilic-acidophilic microorganisms from
          thermal springs, and environmental halophilic isolates.
        </p>
      </Entry>
    </div>
  </section>

  <SectionDivider label="Technical Skills" />

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <span class="section-head__eyebrow">Methods &amp; Tools</span>
        <span class="section-head__line"></span>
      </div>

      <div class="reveal">
        <div class="skills-group">
          <h3>Laboratory &amp; Biological Methods</h3>
          <div class="keywords">
            <span class="keyword">Microbial Cultivation</span>
            <span class="keyword">Environmental Sampling</span>
            <span class="keyword">Ecological Field Records</span>
            <span class="keyword">Morphotype Characterization</span>
            <span class="keyword">Yeast Handling</span>
            <span class="keyword">Cell Physiology</span>
            <span class="keyword">Microscopy</span>
          </div>
        </div>

        <div class="skills-group">
          <h3>Quantitative &amp; Computational</h3>
          <div class="keywords">
            <span class="keyword">R</span>
            <span class="keyword">Python</span>
            <span class="keyword">Linux / Bash</span>
            <span class="keyword">LaTeX</span>
            <span class="keyword">QGIS</span>
            <span class="keyword">Data Visualization</span>
            <span class="keyword">Bioinformatics</span>
          </div>
        </div>

        <div class="skills-group">
          <h3>Scientific &amp; Digital Workflows</h3>
          <div class="keywords">
            <span class="keyword">Scientific Writing</span>
            <span class="keyword">Research Communication</span>
            <span class="keyword">Literature Synthesis</span>
            <span class="keyword">Figure Preparation</span>
          </div>
        </div>

        <div class="skills-group">
          <h3>Languages</h3>
          <div class="keywords">
            <span class="keyword">Spanish (native)</span>
            <span class="keyword">English (working proficiency)</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
