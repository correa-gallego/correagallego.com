---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { getCollection, render } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const renderedProjects = await Promise.all(
  projects.map(async (project) => ({
    project,
    Content: (await render(project)).Content,
  }))
);
---

<Base title="Research — Sebastian Correa-Gallego" description="Research projects, scientific questions, and methods guiding the current stage of my academic work.">
  <header class="page-intro">
    <div class="container">
      <span class="page-intro__eyebrow">Research</span>
      <h1>Research organized around life under constraint</h1>
      <p class="page-intro__lede">
        My current projects live at different biological scales, but they are connected by one
        persistent question: how living systems reorganize when light, nutrients, and energy
        become limiting.
      </p>
    </div>
  </header>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Current projects</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Two systems, two biological scales, one recurring scientific question.</h2>
      <p class="section-lede reveal">
        These projects are not identical in method or setting, but they belong together in my
        portfolio because both ask how life reorganizes when resources, energy, or environmental
        conditions become restrictive.
      </p>
    </div>
    <div class="container container--wide">
      {renderedProjects.map(({ project, Content }, index) => (
        <ProjectCard
          id={project.id}
          title={project.data.title}
          role={project.data.role}
          advisor={project.data.advisor}
          pi={project.data.pi}
          image={project.data.image}
          imageAlt={project.data.imageAlt}
          status={project.data.status}
          reversed={index % 2 === 1}
          aspectRatio={project.data.aspectRatio}
          tags={project.data.tags}
        >
          <Content />
        </ProjectCard>
      ))}
    </div>
  </section>

  <SectionDivider label="Scientific Questions" />

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Questions</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Three threads that keep reappearing in my work.</h2>
      <div class="focus-grid reveal-stagger">
        <article class="focus-card reveal">
          <p class="focus-card__eyebrow">Community structure</p>
          <h3 class="focus-card__title">How do microbial communities assemble along environmental gradients?</h3>
          <p class="focus-card__text">Especially in caves and other systems where energy inputs are low, spatial structure is sharp, and ecological change is compressed into a readable gradient.</p>
        </article>
        <article class="focus-card reveal">
          <p class="focus-card__eyebrow">Physiology</p>
          <h3 class="focus-card__title">How do cells redistribute effort under changing metabolic conditions?</h3>
          <p class="focus-card__text">The yeast mitochondria project made this question tangible by linking carbon regime, proteome allocation, and cellular organization.</p>
        </article>
        <article class="focus-card reveal">
          <p class="focus-card__eyebrow">Integration</p>
          <h3 class="focus-card__title">How can field biology and quantitative reasoning remain connected?</h3>
          <p class="focus-card__text">I want my work to keep moving between natural systems, analytical methods, and the theoretical framing that makes results biologically meaningful.</p>
        </article>
      </div>
    </div>
  </section>

  <SectionDivider label="Technical Skills" />

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Methods &amp; tools</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">The practical toolkit I’m building around these questions.</h2>

      <div class="reveal">
        <div class="skills-group">
          <h3>Laboratory &amp; Biological Methods</h3>
          <div class="keywords">
            <span class="keyword">Microbial Cultivation</span>
            <span class="keyword">Environmental Sampling</span>
            <span class="keyword">Ecological Field Records</span>
            <span class="keyword">Morphotype Characterization</span>
            <span class="keyword">Yeast Handling</span>
            <span class="keyword">Cell Physiology</span>
            <span class="keyword">Microscopy</span>
          </div>
        </div>

        <div class="skills-group">
          <h3>Quantitative &amp; Computational</h3>
          <div class="keywords">
            <span class="keyword">R</span>
            <span class="keyword">Python</span>
            <span class="keyword">Linux / Bash</span>
            <span class="keyword">LaTeX</span>
            <span class="keyword">QGIS</span>
            <span class="keyword">Data Visualization</span>
            <span class="keyword">Bioinformatics</span>
          </div>
        </div>

        <div class="skills-group">
          <h3>Scientific &amp; Digital Workflows</h3>
          <div class="keywords">
            <span class="keyword">Scientific Writing</span>
            <span class="keyword">Research Communication</span>
            <span class="keyword">Literature Synthesis</span>
            <span class="keyword">Figure Preparation</span>
            <span class="keyword">Data Organization</span>
          </div>
        </div>

        <div class="skills-group">
          <h3>Languages</h3>
          <div class="keywords">
            <span class="keyword">Spanish (native)</span>
            <span class="keyword">English (working proficiency)</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
