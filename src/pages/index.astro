---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import Media from '../components/Media.astro';
---

<Base title="Sebastian Correa-Gallego — Microbial ecology & evolutionary cell biology" ogType="profile" variant="full">
  <HeroSection
    title="Sebastian Correa-Gallego"
    tagline="Microbial ecology · Evolutionary cell biology · Natural systems"
  />

  <section class="section section--first">
    <div class="container">
      <div class="section-head reveal">
        <span class="section-head__eyebrow">About</span>
        <span class="section-head__line"></span>
      </div>

      <div class="about reveal">
        <img
          src="/assets/profile.jpg"
          alt="Portrait of Sebastian Correa-Gallego"
          class="about-photo"
          width="140"
          height="140"
          loading="eager"
          decoding="async"
        />
        <div class="about-body">
          <p>
            I study how microbial life organizes under constraint. My work spans from the
            community structure of cultivable microorganisms in tropical volcanic caves to the
            cellular economics of resource allocation in yeast &mdash; two scales of a shared
            question: how biological systems negotiate energy, nutrients, and environmental
            limitation.
          </p>
          <p>
            As an undergraduate researcher at Universidad EAFIT, I investigate microbial
            community assembly along environmental gradients in the Organal San Antonio, a
            volcaniclastic cave system in the Colombian Andes. At Purdue University, I
            contributed to ongoing research on mitochondrial proteome allocation in eukaryotes
            under varying carbon regimes.
          </p>
          <p>
            I am broadly interested in microbial ecology, evolutionary cell biology, and the
            integrative study of natural systems &mdash; particularly where fieldwork,
            quantitative analysis, and biological theory converge.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <span class="section-head__eyebrow">Research Interests</span>
        <span class="section-head__line"></span>
      </div>
      <div class="keywords reveal">
        <span class="keyword">Microbial Ecology</span>
        <span class="keyword">Evolutionary Cell Biology</span>
        <span class="keyword">Subterranean Biology</span>
        <span class="keyword">Geomicrobiology</span>
        <span class="keyword">Biogeochemistry</span>
        <span class="keyword">Environmental Microbiology</span>
        <span class="keyword">Natural Systems</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="section-head__eyebrow">Selected Work</span>
        <span class="section-head__line"></span>
      </div>

      <div class="work-grid reveal-stagger">
        <a href="/research/#cave" class="work-card reveal">
          <Media
            src="/assets/project-cave.jpg"
            alt="Cave microbial ecology"
            placeholder="cave"
            aspectRatio="3 / 2"
          />
          <h3 class="work-card__title">Cultivable communities in a tropical volcaniclastic cave</h3>
          <p class="work-card__desc">
            Microbial community structure and assembly along a light gradient in the Organal San Antonio,
            Colombian Andes.
          </p>
          <span class="work-card__more">Read more</span>
        </a>

        <a href="/research/#yeast" class="work-card reveal">
          <Media
            src="/assets/project-yeast.jpg"
            alt="Yeast proteome allocation"
            placeholder="yeast"
            aspectRatio="3 / 2"
          />
          <h3 class="work-card__title">Proteome allocation in yeast under carbon regimes</h3>
          <p class="work-card__desc">
            Mitochondrial resource allocation and cellular organization in <em>Saccharomyces cerevisiae</em>
            across physiological conditions.
          </p>
          <span class="work-card__more">Read more</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <span class="section-head__eyebrow">Contact</span>
        <span class="section-head__line"></span>
      </div>
      <div class="contact-links reveal">
        <a href="mailto:scorreag6@eafit.edu.co" aria-label="Email Sebastian Correa-Gallego">scorreag6@eafit.edu.co</a>
        <a href="https://www.linkedin.com/in/s-correag" target="_blank" rel="noopener" aria-label="LinkedIn profile (opens in new tab)">LinkedIn</a>
        <a href="https://github.com/correa-gallego" target="_blank" rel="noopener" aria-label="GitHub profile (opens in new tab)">GitHub</a>
      </div>
    </div>
  </section>
</Base>
