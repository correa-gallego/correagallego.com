---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import Media from '../components/Media.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Sebastian Correa-Gallego — microbial ecology and natural systems"
  description="Academic website of Sebastian Correa-Gallego, a Biology undergraduate in Colombia working on cultivable cave microbiology and mitochondrial physiology in yeast."
  ogType="profile"
  variant="full"
>
  <HeroSection
    eyebrow="B.Sc. Biology · Colombia"
    title="Sebastian Correa-Gallego"
    tagline="Biology undergraduate in Colombia studying cultivable cave microbiology and mitochondrial physiology in yeast."
    video="https://svs.gsfc.nasa.gov/vis/a000000/a005400/a005425/perpetual_ocean2_CLOSE_096_temperature_1080p30.mp4"
    videoType="video/mp4"
    poster="/assets/images/perpetual-ocean2-temperature.jpg"
    posterAlt="NASA Scientific Visualization Studio rendering of Earth and ocean-temperature currents."
    actions={[
      { href: '/research/', label: 'Explore research' },
      { href: '/cv/', label: 'Open CV', variant: 'ghost' },
    ]}
    facts={[
      { label: 'Current stage', value: 'B.Sc. Biology at Universidad EAFIT' },
      { label: 'Main project', value: 'Cultivable cave microbiology along a light gradient' },
      { label: 'Ongoing work', value: 'Yeast mitochondria collaboration with Purdue' },
    ]}
    credit={{
      label: 'Visual reference: NASA Scientific Visualization Studio, Perpetual Ocean 2',
      href: 'https://svs.gsfc.nasa.gov/5425',
    }}
  />

  <section id="content-start" class="section section--first">
    <div class="container container--wide">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">About</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Current training</h2>
      <p class="section-lede reveal">
        A concise account of the route that currently defines the portfolio.
      </p>

      <div class="about about--split reveal">
        <img
          src="/assets/profile.jpg"
          alt="Portrait of Sebastian Correa-Gallego"
          class="about-photo"
          width="140"
          height="140"
          loading="eager"
          decoding="async"
        />
        <div class="about-body">
          <p>
            My interest in natural systems began before university. During childhood, I
            participated in a local group focused on atmospheric observation and weather
            monitoring, which gave me an early habit of paying attention to environmental
            variation and to the disciplined recording of natural phenomena.
          </p>
          <p>
            At Universidad EAFIT, that orientation moved into biology and microbiology. My
            undergraduate thesis examines cultivable microbial community structure along a light
            gradient in a tropical volcaniclastic cave in Antioquia, Colombia, using
            environmental characterization, cultivation workflows, and morphotype-based
            assessment.
          </p>
          <p>
            As a Visiting Student Intern in the ECSO Lab at Purdue University, I worked on the
            Yeast Mitochondria Project, which studies proteomic resource allocation under
            different carbon regimes in eukaryotes using yeast as a model system. The work
            continues through collaborative manuscript preparation.
          </p>
          <p>
            At this stage, the route is still being narrowed with care. The common thread is an
            attempt to connect microbial ecology, evolution, and physiology without forcing
            those areas into separate tracks too early.
          </p>
        </div>
        <aside class="profile-panel reveal">
          <p class="profile-panel__eyebrow">Current stage</p>
          <ul class="profile-panel__list">
            <li>Finishing the B.Sc. in Biology at Universidad EAFIT.</li>
            <li>Writing a thesis on cultivable microbial communities along a cave light gradient.</li>
            <li>Continuing manuscript work related to the Purdue yeast mitochondria project.</li>
            <li>Building stronger quantitative and computational routines around ecological questions.</li>
          </ul>
          <div class="institution-strip" aria-label="Institutional context">
            <img src="/assets/logo/EAFIT.svg" alt="Universidad EAFIT" class="institution-strip__logo institution-strip__logo--eafit" loading="lazy" decoding="async" />
            <img src="/assets/logo/Purdue.svg" alt="Purdue University" class="institution-strip__logo institution-strip__logo--purdue" loading="lazy" decoding="async" />
          </div>
          <a href="/trajectory/" class="profile-panel__link">See trajectory</a>
        </aside>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--wide">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Selected work</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Projects that currently anchor the portfolio</h2>

      <div class="work-grid reveal-stagger">
        {projects.map((project) => (
          <a href={`/research/#${project.id}`} class="work-card reveal">
            <Media
              src={project.data.image}
              alt={project.data.imageAlt}
              placeholder={project.data.placeholder}
              aspectRatio={project.data.aspectRatio}
              label=""
            />
            <h3 class="work-card__title">{project.data.title}</h3>
            <p class="work-card__desc">{project.data.lede}</p>
            <span class="work-card__more">Read more</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--wide">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Research interests</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Current areas of interest</h2>
      <div class="home-columns reveal">
        <div class="home-columns__text">
          <p>
            My current interests are centered on microbial life in natural systems: how
            environmental gradients, energetic limitation, and local physicochemical conditions
            shape community structure; how microorganisms interact within those settings; and
            how those processes connect to larger questions in ecology and evolution. I am also
            interested in energy flow in the Earth system, the role of microorganisms in
            planetary history, the origin of life, and the major transitions through which
            biological complexity has emerged. These areas provide the theoretical frame from
            which I am trying to define a more precise long-term research question.
          </p>
        </div>
        <div class="home-columns__list">
          <ul class="plain-list">
            <li>Microbial ecology in environmental and energetic gradients</li>
            <li>Interactions among microorganisms in natural systems</li>
            <li>Energy flow, biogeochemical structure, and Earth-system history</li>
            <li>Origin of life, evolutionary transitions, and biological complexity</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--wide">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Working profile</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Methods and technical profile</h2>
      <div class="home-columns reveal">
        <div class="home-columns__text">
          <p>
            My current work combines cultivation-based microbiology, environmental sampling,
            microscopy, literature synthesis, and quantitative workflows in R and Python. From
            Purdue, I added training in cell physiology, cell harvesting, growth-curve work,
            and the handling of laboratory workflows associated with yeast-based experimental
            systems. I also use GitHub, LaTeX, and basic bioinformatic tools, and I maintain a
            strong interest in figure design, vector-based graphics, and scientific
            communication.
          </p>
        </div>
        <div class="home-columns__list">
          <ul class="plain-list">
            <li>Cultivation workflows, field records, microscopy, and morphotype assessment</li>
            <li>Cell harvesting, growth curves, and basic cell-physiology workflows</li>
            <li>R, Python, GitHub, LaTeX, Linux, Bash, and basic bioinformatics</li>
            <li>Vector graphics, figure preparation, and scientific communication</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Contact</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Academic contact</h2>
      <p class="section-lede reveal">
        Email is the best route for academic contact. Other links are included for reference.
      </p>
      <div class="contact-links reveal">
        <a href="mailto:scorreag6@eafit.edu.co" aria-label="Email Sebastian Correa-Gallego">scorreag6@eafit.edu.co</a>
        <a href="https://www.linkedin.com/in/s-correag" target="_blank" rel="noopener" aria-label="LinkedIn profile (opens in new tab)">LinkedIn</a>
        <a href="https://github.com/correa-gallego" target="_blank" rel="noopener" aria-label="GitHub profile (opens in new tab)">GitHub</a>
        <a href="/cv/" aria-label="Curriculum Vitae">Curriculum Vitae</a>
      </div>
    </div>
  </section>
</Base>
