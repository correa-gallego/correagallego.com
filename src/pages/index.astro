---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import Media from '../components/Media.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Sebastian Correa-Gallego — microbial ecology, evolution, and natural systems"
  description="Early-career academic portfolio of Sebastian Correa-Gallego, Biology undergraduate at Universidad EAFIT working across microbial ecology, evolutionary cell biology, and natural systems."
  ogType="profile"
  variant="full"
>
  <HeroSection
    title="Sebastian Correa-Gallego"
    tagline="An early-career biologist studying how life organizes under constraint, from microbial communities in tropical caves to the cellular economics of mitochondria in yeast."
    video="/assets/video/earth-moon-loop.mp4"
    poster="/assets/images/earth-poster.jpg"
    actions={[
      { href: '/research/', label: 'Explore research' },
      { href: '/cv/', label: 'Open CV', variant: 'ghost' },
    ]}
    facts={[
      { label: 'Current stage', value: 'Biology undergraduate at Universidad EAFIT' },
      { label: 'Main project', value: 'Thesis on cultivable cave microbial communities' },
      { label: 'Ongoing collaboration', value: 'Yeast mitochondria project with Purdue' },
    ]}
    credit={{
      label: 'Hero motion uses NASA Scientific Visualization Studio imagery',
      href: 'https://science.nasa.gov/resource/earth-and-moon/',
    }}
  />

  <section id="content-start" class="section section--first">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Profile</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">A scientific trajectory still in formation, but already organized by a clear question.</h2>
      <p class="section-lede reveal">
        I am not presenting myself as a finished scientist. This site is meant to show the
        shape of the work I have done so far, the questions that now guide me, and the kind
        of research environment I am preparing to grow into.
      </p>

      <div class="about about--split reveal">
        <img
          src="/assets/profile.jpg"
          alt="Portrait of Sebastian Correa-Gallego"
          class="about-photo"
          width="140"
          height="140"
          loading="eager"
          decoding="async"
        />
        <div class="about-body">
          <p>
            I study how microbial life organizes under constraint. My current work spans
            microbial community structure in tropical volcaniclastic caves and mitochondrial
            resource allocation in yeast &mdash; two scales of one broader scientific interest:
            how living systems respond to limitation, restructure themselves, and persist.
          </p>
          <p>
            At Universidad EAFIT, I am developing my undergraduate thesis on cultivable
            microbial communities along a light gradient in the Organal San Antonio cave
            system in Antioquia, Colombia. Through Purdue University, I remain connected to a
            collaboration on mitochondrial proteome allocation in yeast under different carbon
            regimes.
          </p>
          <p>
            I am most interested in the intersections among microbial ecology, evolution,
            physiology, and natural systems. Over time, I want to keep building the ability to
            move between field observation, laboratory reasoning, and quantitative analysis
            without losing the biological story.
          </p>
        </div>
        <aside class="profile-panel reveal">
          <p class="profile-panel__eyebrow">Right now</p>
          <ul class="profile-panel__list">
            <li>Finishing a Biology degree at Universidad EAFIT.</li>
            <li>Writing a thesis on microbial community structure in a tropical cave system.</li>
            <li>Developing an academic profile that connects ecology, evolution, and cell physiology.</li>
          </ul>
          <a href="/trajectory/" class="profile-panel__link">Read the trajectory page</a>
        </aside>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Scientific direction</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">The themes I want my work to keep orbiting.</h2>
      <div class="focus-grid reveal-stagger">
        <article class="focus-card reveal">
          <p class="focus-card__eyebrow">Ecology</p>
          <h3 class="focus-card__title">Microbial life in natural gradients</h3>
          <p class="focus-card__text">Community assembly, environmental limitation, and the ecological logic of caves and other low-energy systems.</p>
        </article>
        <article class="focus-card reveal">
          <p class="focus-card__eyebrow">Cell biology</p>
          <h3 class="focus-card__title">Resource allocation across scales</h3>
          <p class="focus-card__text">How cells distribute effort, matter, and energy when metabolism changes or environmental conditions become restrictive.</p>
        </article>
        <article class="focus-card reveal">
          <p class="focus-card__eyebrow">Future training</p>
          <h3 class="focus-card__title">Graduate work with range</h3>
          <p class="focus-card__text">Research environments where field-based biology, theory, and quantitative methods can remain in active conversation.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Selected work</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Two projects that currently define my portfolio.</h2>

      <div class="work-grid reveal-stagger">
        {projects.map((project) => (
          <a href={`/research/#${project.id}`} class="work-card reveal">
            <Media
              src={project.data.image}
              alt={project.data.imageAlt}
              placeholder="field"
              aspectRatio={project.data.aspectRatio}
              label=""
            />
            <h3 class="work-card__title">{project.data.title}</h3>
            <p class="work-card__desc">{project.data.lede}</p>
            <span class="work-card__more">Read more</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Scientific profile</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Methods, themes, and tools I’m actively growing.</h2>
      <div class="keywords reveal">
        <span class="keyword">Microbial Ecology</span>
        <span class="keyword">Subterranean Biology</span>
        <span class="keyword">Evolutionary Cell Biology</span>
        <span class="keyword">Cultivation Workflows</span>
        <span class="keyword">Environmental Sampling</span>
        <span class="keyword">R</span>
        <span class="keyword">Python</span>
        <span class="keyword">Scientific Writing</span>
        <span class="keyword">Data Interpretation</span>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Contact</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">If you are reaching out about collaboration, graduate study, or scientific conversation, this is the best place to start.</h2>
      <div class="contact-links reveal">
        <a href="mailto:scorreag6@eafit.edu.co" aria-label="Email Sebastian Correa-Gallego">scorreag6@eafit.edu.co</a>
        <a href="https://www.linkedin.com/in/s-correag" target="_blank" rel="noopener" aria-label="LinkedIn profile (opens in new tab)">LinkedIn</a>
        <a href="https://github.com/correa-gallego" target="_blank" rel="noopener" aria-label="GitHub profile (opens in new tab)">GitHub</a>
        <a href="/cv/" aria-label="Curriculum Vitae">Curriculum Vitae</a>
      </div>
    </div>
  </section>
</Base>
