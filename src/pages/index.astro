---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import Media from '../components/Media.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Sebastian Correa-Gallego — microbial ecology, evolution, and natural systems"
  description="Early-career academic portfolio of Sebastian Correa-Gallego, Biology undergraduate at Universidad EAFIT working across microbial ecology, evolutionary cell biology, and natural systems."
  ogType="profile"
  variant="full"
>
  <HeroSection
    title="Sebastian Correa-Gallego"
    tagline="Biology undergraduate at Universidad EAFIT studying microbial ecology, evolution, and natural systems, from cultivable cave communities to mitochondrial resource allocation in yeast."
    video="/assets/video/perpetual-ocean.webm"
    poster="/assets/images/perpetual-ocean-poster.jpg"
    actions={[
      { href: '/research/', label: 'Explore research' },
      { href: '/cv/', label: 'Open CV', variant: 'ghost' },
    ]}
    facts={[
      { label: 'Current stage', value: 'Biology undergraduate at Universidad EAFIT' },
      { label: 'Main project', value: 'Thesis on cultivable cave microbial communities' },
      { label: 'Ongoing collaboration', value: 'Yeast mitochondria project with Purdue' },
    ]}
    credit={{
      label: 'Hero motion uses NASA Scientific Visualization Studio: Perpetual Ocean',
      href: 'https://svs.gsfc.nasa.gov/3827',
    }}
  />

  <section id="content-start" class="section section--first">
    <div class="container container--wide">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Profile</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">An early academic profile shaped by microbial life, natural systems, and environmental gradients.</h2>
      <p class="section-lede reveal">
        This is not a claim to a finished identity. It is a working account of the questions,
        projects, and methods that have begun to give my scientific trajectory a clearer form.
      </p>

      <div class="about about--split reveal">
        <img
          src="/assets/profile.jpg"
          alt="Portrait of Sebastian Correa-Gallego"
          class="about-photo"
          width="140"
          height="140"
          loading="eager"
          decoding="async"
        />
        <div class="about-body">
          <p>
            I am interested in microbial ecology and evolution in natural systems. The main
            through-line in my work is how life organizes under constraint: across light
            gradients, low-energy habitats, and changing physiological regimes.
          </p>
          <p>
            My undergraduate thesis examines cultivable microbial community structure along a
            light gradient in the Organal San Antonio cave system, a tropical volcaniclastic
            cave in Antioquia, Colombia. It is a field-to-lab project grounded in ecological
            observation, cultivation work, and environmental characterization.
          </p>
          <p>
            Through the ECSO Lab at Purdue University, I also contributed to the Yeast
            Mitochondria Project on proteomic resource allocation under different carbon
            regimes. Together, these projects have pushed me toward a route that connects
            ecology, physiology, and evolutionary reasoning rather than separating them.
          </p>
          <p>
            In the longer term, I want to keep a naturalist orientation while building stronger
            quantitative and computational discipline. What matters to me is not abandoning the
            biological story for abstraction, but learning how to study natural systems with
            greater precision.
          </p>
        </div>
        <aside class="profile-panel reveal">
          <p class="profile-panel__eyebrow">Current route</p>
          <ul class="profile-panel__list">
            <li>Finishing a Biology degree at Universidad EAFIT.</li>
            <li>Writing a thesis on cultivable microbial communities in a tropical cave system.</li>
            <li>Maintaining an ongoing collaboration on mitochondrial resource allocation in yeast.</li>
            <li>Trying to integrate ecology, evolution, physiology, and natural history into one coherent line of work.</li>
          </ul>
          <a href="/trajectory/" class="profile-panel__link">Read the trajectory page</a>
        </aside>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--wide">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Scientific direction</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">The intellectual route I am trying to make more coherent.</h2>
      <div class="focus-grid reveal-stagger">
        <article class="focus-card reveal">
          <p class="focus-card__eyebrow">Natural systems</p>
          <h3 class="focus-card__title">Microbial life in gradients and low-energy environments</h3>
          <p class="focus-card__text">Caves, environmental transitions, and ecological settings where limitation is strong enough to reveal structure clearly.</p>
        </article>
        <article class="focus-card reveal">
          <p class="focus-card__eyebrow">Constraint</p>
          <h3 class="focus-card__title">Physiology, resource allocation, and cellular organization</h3>
          <p class="focus-card__text">Questions about how cells redistribute matter and effort when energy sources shift or environmental conditions become restrictive.</p>
        </article>
        <article class="focus-card reveal">
          <p class="focus-card__eyebrow">Method</p>
          <h3 class="focus-card__title">Natural history with stronger quantitative discipline</h3>
          <p class="focus-card__text">A route that keeps ecological and naturalist reasoning intact while demanding more analytical and computational rigor over time.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--wide">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Selected work</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Two projects that currently anchor the portfolio.</h2>

      <div class="work-grid reveal-stagger">
        {projects.map((project) => (
          <a href={`/research/#${project.id}`} class="work-card reveal">
            <Media
              src={project.data.image}
              alt={project.data.imageAlt}
              placeholder={project.data.placeholder}
              aspectRatio={project.data.aspectRatio}
              label=""
            />
            <h3 class="work-card__title">{project.data.title}</h3>
            <p class="work-card__desc">{project.data.lede}</p>
            <span class="work-card__more">Read more</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--wide">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Scientific profile</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Current methods, themes, and working vocabulary.</h2>
      <div class="keywords reveal">
        <span class="keyword">Microbial Ecology</span>
        <span class="keyword">Subterranean Biology</span>
        <span class="keyword">Evolutionary Cell Biology</span>
        <span class="keyword">Cultivation Workflows</span>
        <span class="keyword">Environmental Sampling</span>
        <span class="keyword">R</span>
        <span class="keyword">Python</span>
        <span class="keyword">Scientific Writing</span>
        <span class="keyword">Data Interpretation</span>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Contact</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">For scientific conversation, collaboration, or graduate-study contact.</h2>
      <div class="contact-links reveal">
        <a href="mailto:scorreag6@eafit.edu.co" aria-label="Email Sebastian Correa-Gallego">scorreag6@eafit.edu.co</a>
        <a href="https://www.linkedin.com/in/s-correag" target="_blank" rel="noopener" aria-label="LinkedIn profile (opens in new tab)">LinkedIn</a>
        <a href="https://github.com/correa-gallego" target="_blank" rel="noopener" aria-label="GitHub profile (opens in new tab)">GitHub</a>
        <a href="/cv/" aria-label="Curriculum Vitae">Curriculum Vitae</a>
      </div>
    </div>
  </section>
</Base>
