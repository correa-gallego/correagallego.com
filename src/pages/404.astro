---
import Base from '../layouts/Base.astro';
---

<Base title="Not Found — Sebastian Correa-Gallego" description="The page you're looking for doesn't exist.">
  <section class="section">
    <div class="container">
      <div class="notfound">
        <p class="notfound-code">404</p>
        <h1>Page not found</h1>
        <p class="notfound-lede">
          The page you're looking for has been moved, renamed, or never existed.
        </p>
        <p class="notfound-actions">
          <a href="/">Return home</a>
          <span aria-hidden="true">·</span>
          <a href="/research/">Research</a>
          <span aria-hidden="true">·</span>
          <a href="/publications/">Publications</a>
        </p>
      </div>
    </div>
  </section>
</Base>
