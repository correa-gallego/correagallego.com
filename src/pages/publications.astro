---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const outputs = (await getCollection('outputs')).sort((a, b) => a.data.order - b.data.order);
const manuscripts = outputs.filter((item) => item.data.kind === 'manuscript');
const presentations = outputs.filter((item) => item.data.kind === 'presentation');
const awards = outputs.filter((item) => item.data.kind === 'award');
const formatAuthors = (authors: string[]) =>
  authors.map((author) => (author === 'Sebastian Correa-Gallego' ? `<strong>${author}</strong>` : author)).join(', ');
---

<Base title="Publications — Sebastian Correa-Gallego" description="Manuscripts in preparation, presentations, and recognitions in the current stage of my academic profile.">
  <header class="page-intro">
    <div class="container">
      <span class="page-intro__eyebrow">Publications</span>
      <h1>Manuscripts, presentations, and early academic recognition</h1>
      <p class="page-intro__lede">
        At this stage of my career, this page is intentionally modest. It captures work in
        preparation, presentations already delivered, and the recognitions that have marked my
        undergraduate development.
      </p>
    </div>
  </header>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Manuscripts in preparation</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Current writing projects</h2>

      <ul class="pub-list reveal">
        {manuscripts.map((item) => (
          <li>
            <p class="pub-authors" set:html={formatAuthors(item.data.authors)} />
            <p class="pub-title">{item.data.title}</p>
            <p class="pub-venue">{item.data.status ?? 'In preparation.'}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Conferences &amp; presentations</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Academic communication</h2>
      <ul class="pub-list reveal">
        {presentations.map((item) => (
          <li>
            <p class="pub-authors">{item.data.year}</p>
            <p class="pub-title">{item.data.title}</p>
            <p class="pub-venue">
              {item.data.venue}
              {item.data.status && ` · ${item.data.status}`}
            </p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <p class="section-head__eyebrow">Honors &amp; recognition</p>
        <span class="section-head__line"></span>
      </div>
      <h2 class="section-title reveal">Markers of the path so far</h2>
      <ul class="pub-list reveal">
        {awards.map((item) => (
          <li>
            <p class="pub-authors">{item.data.year}</p>
            <p class="pub-title">{item.data.title}</p>
            <p class="pub-venue">{item.data.venue}</p>
          </li>
        ))}
      </ul>
      <div class="publications-note reveal">
        <p>
          This page will grow as manuscripts move into submission and my academic output expands.
          For now, it aims to be accurate rather than inflated.
        </p>
      </div>
    </div>
  </section>
</Base>
