---
interface Props {
  title: string;
  date: string;
  role?: string;
  note?: string;
  id?: string;
}
const { title, date, role, note, id } = Astro.props;
---

<div class="entry reveal" id={id}>
  <div class="entry-header">
    <h3>{title}</h3>
    <span class="entry-date">{date}</span>
  </div>
  {role && <p class="entry-role">{role}</p>}
  <slot />
  {note && <span class="entry-note">{note}</span>}
</div>
