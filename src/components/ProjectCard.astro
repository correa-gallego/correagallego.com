---
import Media from './Media.astro';

interface Props {
  title: string;
  role: string;
  advisor?: string;
  pi?: string;
  institutionName?: string;
  institutionLogo?: string;
  image?: string;
  imageAlt?: string;
  placeholder?: 'cave' | 'cave-deep' | 'yeast' | 'field';
  status?: string;
  reversed?: boolean;
  aspectRatio?: string;
  id?: string;
  tags?: string[];
}

const {
  title,
  role,
  advisor,
  pi,
  institutionName,
  institutionLogo,
  image,
  imageAlt = '',
  placeholder = 'field',
  status,
  reversed = false,
  aspectRatio = '3 / 2',
  id,
  tags = [],
} = Astro.props;
---

<article class:list={['project reveal', { 'project--reversed': reversed }]} id={id}>
  <div class="project__media">
    <Media
      src={image}
      alt={imageAlt}
      placeholder={placeholder}
      aspectRatio={aspectRatio}
      label=""
    />
  </div>
  <div class="project__body">
    <h3 class="project__title">{title}</h3>
    <p class="project__role">{role}</p>
    {institutionName && institutionLogo && (
      <div class="project__institution" aria-label={`Institution: ${institutionName}`}>
        <img
          src={institutionLogo}
          alt=""
          class="project__institution-logo"
          loading="lazy"
          decoding="async"
        />
        <span>{institutionName}</span>
      </div>
    )}
    {(advisor || pi) && (
      <ul class="project__meta">
        {advisor && <li><span class="project__meta-label">Advisor</span> {advisor}</li>}
        {pi && <li><span class="project__meta-label">PI</span> {pi}</li>}
      </ul>
    )}
    <div class="project__description">
      <slot />
    </div>
    {tags.length > 0 && (
      <div class="keywords">
        {tags.map((tag) => <span class="keyword">{tag}</span>)}
      </div>
    )}
    {status && <span class="entry-note">{status}</span>}
    <div class="project__support">
      <slot name="support" />
    </div>
  </div>
</article>
